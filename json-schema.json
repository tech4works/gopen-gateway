{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gopen Schema",
  "type": "object",
  "definitions": {
    "url": {
      "type": "string"
    },
    "byte-unit": {
      "type": "string",
      "pattern": "^(?:\\d+(?:B|KB|MB|GB|TB|PB|EB|ZB|YB)|\\$[A-Za-z_][A-Za-z_0-9]*)$"
    },
    "duration": {
      "type": "string",
      "pattern": "^(?:\\d+(?:\\.\\d+)?(?:h|m|s|ms|us|ns)|\\$[A-Za-z_][A-Za-z_0-9]*)$"
    },
    "only-if": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ignore-if": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "path": {
      "type": "string"
    },
    "http-method": {
      "type": "string",
      "enum": [
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS",
        "GET"
      ]
    },
    "json-path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[\\w-]+(\\.[\\w-]+)*$"
    },
    "nomenclature": {
      "type": "string",
      "enum": [
        "LOWER_CAMEL",
        "CAMEL",
        "SNAKE",
        "SCREAMING_SNAKE",
        "KEBAB",
        "SCREAMING_KEBAB"
      ]
    },
    "content-type": {
      "type": "string",
      "enum": [
        "JSON",
        "XML",
        "PLAIN_TEXT"
      ]
    },
    "content-encoding": {
      "type": "string",
      "enum": [
        "GZIP",
        "DEFLATE",
        "NONE"
      ]
    },
    "backend-kind": {
      "type": "string",
      "enum": [
        "HTTP",
        "PUBLISHER"
      ]
    },
    "template-merge": {
      "type": "string",
      "enum": [
        "BASE",
        "FULL"
      ]
    },
    "component-merge": {
      "type": "string",
      "enum": [
        "EXTEND",
        "OVERRIDE"
      ]
    },
    "execution-mode": {
      "type": "string",
      "enum": [
        "FAIL_FAST",
        "BEST_EFFORT"
      ]
    },
    "execution-on": {
      "type": "string",
      "enum": [
        "BUILD",
        "CLIENT_ERROR",
        "SERVER_ERROR"
      ]
    },
    "modifier-action": {
      "type": "string",
      "enum": [
        "ADD",
        "APPEND",
        "SET",
        "REPLACE",
        "DELETE"
      ]
    },
    "attribute-value-type": {
      "type": "string",
      "enum": [
        "STRING",
        "NUMBER",
        "BINARY"
      ]
    },
    "backend-broker": {
      "type": "string",
      "enum": [
        "AWS/SQS",
        "AWS/SNS"
      ]
    },
    "mapper-policy": {
      "type": "string",
      "enum": [
        "KEEP_UNMAPPED",
        "DROP_UNMAPPED"
      ]
    },
    "join-target-on-missing": {
      "type": "string",
      "enum": [
        "OMIT",
        "NULL",
        "ERROR"
      ]
    },
    "join-target-policy": {
      "type": "string",
      "enum": [
        "KEEP_KEY",
        "DROP_KEY_ON_MERGED",
        "DROP_KEY_ALWAYS"
      ]
    },
    "template": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "merge": {
          "$ref": "#/definitions/template-merge"
        }
      },
      "required": [
        "path"
      ],
      "additionalProperties": false
    },
    "templates": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "beforewares": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/backend-middleware"
          }
        },
        "backends": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/backend-normal"
          }
        },
        "afterwares": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/backend-middleware"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "beforewares"
          ]
        },
        {
          "required": [
            "backends"
          ]
        },
        {
          "required": [
            "afterwares"
          ]
        }
      ],
      "additionalProperties": false
    },
    "request-client-propagate": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "request": {
          "type": "string"
        },
        "response": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "request-client-value": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallback": {
          "type": "boolean"
        },
        "propagate": {
          "$ref": "#/definitions/request-client-propagate"
        }
      },
      "additionalProperties": false
    },
    "request-client-ip": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "trusted-proxies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "propagate": {
          "$ref": "#/definitions/request-client-propagate"
        }
      },
      "additionalProperties": false
    },
    "transport-headers-request": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "degradation":  { "type": "boolean" },
        "timeout":      { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "transport-headers-response": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "cache":            { "type": "boolean" },
        "backend-cache":    { "type": "boolean" },
        "execution-status": { "type": "boolean" },
        "degradation":      { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "transport-headers": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "request":  { "$ref": "#/definitions/transport-headers-request" },
        "response": { "$ref": "#/definitions/transport-headers-response" }
      },
      "additionalProperties": false
    },
    "request-client": {
      "type": "object",
      "properties": {
        "@comment": { "type": "string" },
        "request-id": {
          "$ref": "#/definitions/request-client-value"
        },
        "trace": {
          "$ref": "#/definitions/request-client-value"
        },
        "ip": {
          "$ref": "#/definitions/request-client-ip"
        },
        "transport-headers": {
          "$ref": "#/definitions/transport-headers"
        }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "properties": {
        "client": {
          "$ref": "#/definitions/request-client"
        }
      },
      "additionalProperties": false
    },
    "store": {
      "type": "object",
      "properties": {
        "redis": {
          "type": "object",
          "properties": {
            "address": {
              "$ref": "#/definitions/url"
            },
            "password": {
              "type": "string"
            }
          },
          "required": [
            "address"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "redis"
      ],
      "additionalProperties": false
    },
    "cache-decision": {
      "type": "object",
      "properties": {
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "cache": {
      "type": "object",
      "properties": {
         "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "read": {
          "$ref": "#/definitions/cache-decision"
        },
        "write": {
          "$ref": "#/definitions/cache-decision"
        },
        "key": {
          "type": "string"
        },
        "ttl": {
          "$ref": "#/definitions/duration"
        }
      },
      "required": [
        "key",
        "ttl"
      ],
      "additionalProperties": false
    },
    "cache-endpoint": {
      "type": "object",
      "properties": {
         "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "read": {
          "$ref": "#/definitions/cache-decision"
        },
        "write": {
          "$ref": "#/definitions/cache-decision"
        },
        "key": {
          "type": "string"
        },
        "ttl": {
          "$ref": "#/definitions/duration"
        }
      },
      "additionalProperties": false
    },
    "limiter-size": {
      "type": "object",
      "properties": {
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "max-header": {
          "$ref": "#/definitions/byte-unit"
        },
        "max-body": {
          "$ref": "#/definitions/byte-unit"
        }
      },
      "anyOf": [
        {
          "required": [
            "max-header"
          ]
        },
        {
          "required": [
            "max-body"
          ]
        }
      ],
      "additionalProperties": false
    },
    "limiter-rate": {
      "type": "object",
      "properties": {
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "every": {
          "$ref": "#/definitions/duration"
        }
      },
      "required": [
        "capacity",
        "every"
      ],
      "additionalProperties": false
    },
    "limiter": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "size": {
          "$ref": "#/definitions/limiter-size"
        },
        "rate": {
          "$ref": "#/definitions/limiter-rate"
        }
      },
      "additionalProperties": false
    },
    "security-cors": {
      "type": "object",
      "properties": {
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "allow-origins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow-methods": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http-method"
          }
        },
        "allow-headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow-credentials": {
          "type": "boolean"
        }
      },
      "anyOf": [
        {
          "required": [
            "allow-origins"
          ]
        },
        {
          "required": [
            "allow-methods"
          ]
        },
        {
          "required": [
            "allow-headers"
          ]
        },
        {
          "required": [
            "allow-credentials"
          ]
        }
      ],
      "additionalProperties": false
    },
    "gopen-execution": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "mode": {
          "$ref": "#/definitions/execution-mode"
        },
        "on": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/execution-on"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "mode"
          ]
        },
        {
          "required": [
            "on"
          ]
        }
      ],
      "additionalProperties": false
    },
    "endpoint-execution": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "parallelism": {
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/definitions/execution-mode"
        },
        "on": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/execution-on"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "parallelism"
          ]
        },
        {
          "required": [
            "mode"
          ]
        },
        {
          "required": [
            "on"
          ]
        }
      ],
      "additionalProperties": false
    },
    "backend-execution": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "concurrent": {
          "type": "integer",
          "minimum": 1
        },
        "async": {
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/definitions/execution-mode"
        },
        "on": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/execution-on"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "concurrent"
          ]
        },
        {
          "required": [
            "async"
          ]
        },
        {
          "required": [
            "mode"
          ]
        },
        {
          "required": [
            "on"
          ]
        }
      ],
      "additionalProperties": false
    },
    "request-modifier": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "action": {
          "$ref": "#/definitions/modifier-action"
        },
        "propagate": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "action": {
            "const": "DELETE"
          }
        }
      },
      "then": {
        "required": [
          "action",
          "key"
        ]
      },
      "else": {
        "required": [
          "action",
          "key",
          "value"
        ]
      },
      "additionalProperties": false
    },
    "response-modifier": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "action": {
          "$ref": "#/definitions/modifier-action"
        },
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "action": {
            "const": "DELETE"
          }
        }
      },
      "then": {
        "required": [
          "action",
          "key"
        ]
      },
      "else": {
        "required": [
          "action",
          "key",
          "value"
        ]
      },
      "additionalProperties": false
    },
    "mapper": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "policy": {
          "$ref": "#/definitions/mapper-policy"
        },
        "map": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/json-path"
          }
        }
      },
      "required": [
        "map"
      ],
      "additionalProperties": false
    },
    "projector": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "project": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "required": [
        "project"
      ],
      "additionalProperties": false
    },
    "join-source": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "path",
        "key"
      ],
      "additionalProperties": false
    },
    "join-target": {
      "type": "object",
      "properties": {
        "policy": {
          "$ref": "#/definitions/join-target-policy"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "as": {
          "type": "string",
          "minLength": 1
        },
        "on-missing": {
          "$ref": "#/definitions/join-target-on-missing"
        }
      },
      "required": [
        "path",
        "key",
        "as"
      ],
      "additionalProperties": false
    },
    "join": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "only-if": {
          "$ref": "#/definitions/only-if"
        },
        "ignore-if": {
          "$ref": "#/definitions/ignore-if"
        },
        "source": {
          "$ref": "#/definitions/join-source"
        },
        "target": {
          "$ref": "#/definitions/join-target"
        }
      },
      "required": [
        "source",
        "target"
      ],
      "additionalProperties": false
    },
    "metadata-transformation": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "omit": {
          "type": "boolean"
        },
        "mapper": {
          "$ref": "#/definitions/mapper"
        },
        "projector": {
          "$ref": "#/definitions/projector"
        },
        "modifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/request-modifier"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "omit"
          ]
        },
        {
          "required": [
            "mapper"
          ]
        },
        {
          "required": [
            "projector"
          ]
        },
        {
          "required": [
            "modifiers"
          ]
        }
      ],
      "additionalProperties": false
    },
    "response-metadata-transformation": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "omit": {
          "type": "boolean"
        },
        "mapper": {
          "$ref": "#/definitions/mapper"
        },
        "projector": {
          "$ref": "#/definitions/projector"
        },
        "modifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/response-modifier"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "omit"
          ]
        },
        {
          "required": [
            "mapper"
          ]
        },
        {
          "required": [
            "projector"
          ]
        },
        {
          "required": [
            "modifiers"
          ]
        }
      ],
      "additionalProperties": false
    },
    "url-path-transformation": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "modifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/request-modifier"
          }
        }
      },
      "required": [
        "modifiers"
      ],
      "additionalProperties": false
    },
    "query-transformation": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "omit": {
          "type": "boolean"
        },
        "mapper": {
          "$ref": "#/definitions/mapper"
        },
        "projector": {
          "$ref": "#/definitions/projector"
        },
        "modifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/request-modifier"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "omit"
          ]
        },
        {
          "required": [
            "mapper"
          ]
        },
        {
          "required": [
            "projector"
          ]
        },
        {
          "required": [
            "modifiers"
          ]
        }
      ],
      "additionalProperties": false
    },
    "backend-request-payload-transformation": {
      "type": "object",
      "properties": {
        "@comment": {
          "type": "string"
        },
        "group": {
          "type": "string",
          "minLength": 1
        },
        "omit": {
          "type": "boolean"
        },
        "omit-empty": {
          "type": "boolean"
        },
        "content-type": {
          "$ref": "#/definitions/content-type"
        },
        "content-encoding": {
          "$ref": "#/definitions/content-encoding"
        },
        "nomenclature": {
          "$ref": "#/definitions/nomenclature"
        },
        "mapper": {
          "$ref": "#/definitions/mapper"
        },
        "projector": {
          "$ref": "#/definitions/projector"
        },
        "modifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/request-modifier"
          }
        },
        "joins": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/join"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "aggregate"
          ]
        },
        {
          "required": [
